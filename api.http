### Get all users
GET {{baseUrl}}/users
Cookie: accessToken={{token}}; refreshToken={{tokenrefresh}}

### Get a user by id
GET {{baseUrl}}/users/{{userId}}
Cookie: accessToken={{token}}
### Update a user by id
PATCH {{baseUrl}}/users/{{userId}}
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "role": "admin"
}

### Delete a user by id
DELETE {{baseUrl}}/users/{{userId}}
Cookie: accessToken={{token}}



### AUTH API-----------------------------------------------------------------



### Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "admin11",
  "email": "admin11@gmail.com",
  "password": "passwordadmin11",
  "phone": "9876543211",
  "role": "admin"
}

### Login a user
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test7@gmail.com",
  "password": "passwordtest7"
}

### Logout a user
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Cookie: accessToken={{token}}

### Refresh access token
POST {{baseUrl}}/auth/refresh
Content-Type: application/json
Cookie: accessToken={{token}}; refreshToken={{tokenrefresh}}

### Get current user profile
GET {{baseUrl}}/auth/me
Content-Type: application/json
Cookie: accessToken={{token}}; refreshToken={{tokenrefresh}}


### USER PREFERENCE API-----------------------------------------------------------------

### Get user preferences
GET {{baseUrl}}/preferences/get
Content-Type: application/json
Cookie: accessToken={{token}}

### Update user preferences
PATCH {{baseUrl}}/preferences/update
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "defaultModel": "gpt-3.5-turbo",
  "temperature": "0.7",
  "theme": "light"
}




### CONVERSATION API-----------------------------------------------------------------

@convId=69aad2036a23db22a37e2f67

### Create a new conversation
POST {{baseUrl}}/conversations
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "title": "My Third Conversation",
  "model": "gpt-3.5-turbo",
  "systemPrompt": "You are a helpful assistant.",
  "visibility": "private",
  "isArchived": "false"
}


### Create a new conversation for guest user
POST {{baseUrl}}/conversations/guest
Content-Type: application/json

{
  "title": "My fourth Conversation",
  "model": "gpt-3.5-turbo",
  "systemPrompt": "You are a helpful assistant.",
  "visibility": "private",
  "isArchived": "false"
}


### Get all conversations for the authenticated user
GET {{baseUrl}}/conversations
Cookie: accessToken={{token}}



### Get a single conversation by ID
GET {{baseUrl}}/conversations/{{convId}}
Cookie: accessToken={{token}}

### Update a conversation by ID
PATCH {{baseUrl}}/conversations/{{convId}}
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "title": "Updated first Conversation Title",
  "model": "gpt-4",
  "systemPrompt": "You are an updated helpful assistant.",
  "visibility": "shared",
  "isArchived": "false"
}

### Delete a conversation by ID
DELETE {{baseUrl}}/conversations/{{convId}}
Cookie: accessToken={{token}}





### MESSAGE API-----------------------------------------------------------------

@messageId=69aad22e6a23db22a37e2fbb
### Add a message to a conversation
POST {{baseUrl}}/messages/conversations/{{convId}}/messages
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "content": "testing make it simple "
}


### Add a message to a conversation by guest user for free
POST {{baseUrl}}/messages/conversations/{{convId}}/messages/guest
Content-Type: application/json

{
  "content": "explain in detail"
}

### Get all messages in a conversation
GET {{baseUrl}}/messages/conversations/{{convId}}/messages
Cookie: accessToken={{token}}

### Update a message in a conversation
PATCH {{baseUrl}}/messages/messages/{{messageId}}
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "content": "can you write mern code?"
}

### Regenerate an assistant message in a conversation
POST {{baseUrl}}/messages/messages/{{messageId}}/regenerate
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "conversationId": "{{convId}}"
}




### MESSAGE VERSION API-----------------------------------------------------------------

@messageVersionId=69aad22e6a23db22a37e2fbb
@conversationId=69aad2036a23db22a37e2f67

### Get all versions of a message
GET {{baseUrl}}/messagesvr/{{conversationId}}/{{messageVersionId}}/versions



### CONTENT FLAG API-----------------------------------------------------------------

@flagId=6998327f5ecb1b98a950e86c



### Flag a message for review automatic system generated
POST {{baseUrl}}/flags
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "messageId": "{{messageId}}",
  "category": "hate",
  "severity": "high"
}



### Get all flagged messages (Admin only)
GET {{baseUrl}}/flags
Cookie: accessToken={{token}}

### Update the action taken on a flagged message (Admin only)
PATCH {{baseUrl}}/flags/{{flagId}}
Content-Type: application/json
Cookie: accessToken={{token}}

{
  "actionTaken": "blocked"
}






### USAGE METRIC API-----------------------------------------------------------------

### Get usage metrics for the authenticated user
GET {{baseUrl}}/metrics/usage
Cookie: accessToken={{token}}

### Get usage metrics for all users (Admin only)
GET {{baseUrl}}/metrics/usage/all
Cookie: accessToken={{token}}









